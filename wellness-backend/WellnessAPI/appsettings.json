      { "Endpoint": "POST:/api/auth/register", "Period": "1h", "Limit": 3 },
      { "Endpoint": "*", "Period": "1m", "Limit": 60 }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Email": {
