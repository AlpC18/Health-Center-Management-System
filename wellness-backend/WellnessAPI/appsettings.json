{
  "DatabaseProvider": "MySql",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=wellness.db",
    "MySqlConnection": "Server=localhost;Port=3306;Database=wellnes;User=root;Password=;SslMode=None;"
  },
  "Jwt": {
    "Key": "WellnessHouse_SuperSecretKey_UBT2025_Min32Chars!!",
    "Issuer": "WellnessAPI",
    "Audience": "WellnessClient"
